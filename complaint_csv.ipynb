    "def get_sentiment(text):\n",
    "    score = TextBlob(str(text)).sentiment.polarity\n",
    "\n",
    "    if score > 0:\n",
    "        return \"Positive\"\n",
    "    elif score < 0:\n",
    "        return \"Negative\"\n",
    "    else:\n",
    "        return \"Neutral\"\n",
    "\n",
    "df[\"Sentiment\"] = df[\"narrative\"].apply(get_sentiment)\n",
    "\n",
    "print(df[[\"product\", \"Sentiment\"]].head())\n",
    "print(df[[\"narrative\", \"Sentiment\"]].head(10))"
   ]
  },
